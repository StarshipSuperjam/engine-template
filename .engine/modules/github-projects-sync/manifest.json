{
  "id": "github-projects-sync",
  "version": "0.1.0",
  "status": "optional",
  "provides": {
    "tool": [
      ".engine/tools/projects_sync/*.py"
    ],
    "operation": [
      ".engine/operations/projects-sync-setup.md"
    ],
    "skill": [
      ".claude/skills/engine-board-setup/SKILL.md"
    ]
  },
  "wires": [
    {
      "type": "gitignore",
      "key": "github-projects-sync-board-config",
      "lines": [
        ".engine/projects-sync/"
      ]
    },
    {
      "type": "hook",
      "event": "SessionStart",
      "matcher": "startup",
      "hook": {
        "type": "command",
        "command": "sh \"${CLAUDE_PROJECT_DIR}/.engine/tools/hook-runner.sh\" \"${CLAUDE_PROJECT_DIR}/.engine/.venv/bin/python\" \"${CLAUDE_PROJECT_DIR}/.engine/tools/projects_sync/projects_sync.py\" session-start"
      }
    },
    {
      "type": "hook",
      "event": "SessionStart",
      "matcher": "resume",
      "hook": {
        "type": "command",
        "command": "sh \"${CLAUDE_PROJECT_DIR}/.engine/tools/hook-runner.sh\" \"${CLAUDE_PROJECT_DIR}/.engine/.venv/bin/python\" \"${CLAUDE_PROJECT_DIR}/.engine/tools/projects_sync/projects_sync.py\" session-start"
      }
    }
  ],
  "depends": {
    "core": ""
  }
}
