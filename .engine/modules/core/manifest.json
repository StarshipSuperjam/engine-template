{
  "id": "core",
  "version": "0.0.0-dev",
  "status": "required",
  "provides": {
    "check": [".engine/check/guardrail-weakening.json", ".engine/check/protection.json"],
    "schema": [".engine/schemas/*.json"],
    "tool": [".engine/tools/*.py"],
    "interface": [".engine/interfaces/*.json"],
    "operation": [".engine/operations/*.md"],
    "skill": [".claude/skills/*/SKILL.md", ".claude/skills/.gitkeep"],
    "agent": [".claude/agents/.gitkeep"],
    "doc": [".engine/docs/*.md"],
    "state": [".engine/state/*.json"],
    "knowledge": [".engine/knowledge/*.json"],
    "contract": [".engine/contracts/*.md", ".engine/contracts/.gitkeep"],
    "policy": [".engine/policies/*.md"],
    "template": [".engine/templates/*.md"],
    "foundation": [".engine/suites.json", ".engine/self-map.md"]
  },
  "wires": [
    {
      "type": "hook",
      "event": "SessionStart",
      "matcher": "startup",
      "hook": {
        "type": "command",
        "command": "${CLAUDE_PROJECT_DIR}/.engine/.venv/bin/python ${CLAUDE_PROJECT_DIR}/.engine/tools/boot.py"
      }
    },
    {
      "type": "hook",
      "event": "SessionStart",
      "matcher": "resume",
      "hook": {
        "type": "command",
        "command": "${CLAUDE_PROJECT_DIR}/.engine/.venv/bin/python ${CLAUDE_PROJECT_DIR}/.engine/tools/boot.py"
      }
    },
    {
      "type": "hook",
      "event": "SessionStart",
      "matcher": "clear",
      "hook": {
        "type": "command",
        "command": "${CLAUDE_PROJECT_DIR}/.engine/.venv/bin/python ${CLAUDE_PROJECT_DIR}/.engine/tools/boot.py"
      }
    },
    {
      "type": "hook",
      "event": "PreToolUse",
      "matcher": "",
      "hook": {
        "type": "command",
        "command": "${CLAUDE_PROJECT_DIR}/.engine/.venv/bin/python ${CLAUDE_PROJECT_DIR}/.engine/tools/modes.py"
      }
    },
    {
      "type": "hook",
      "event": "PreToolUse",
      "matcher": "",
      "hook": {
        "type": "command",
        "command": "${CLAUDE_PROJECT_DIR}/.engine/.venv/bin/python ${CLAUDE_PROJECT_DIR}/.engine/tools/knowledge_gen.py hook"
      }
    },
    {
      "type": "hook",
      "event": "PostToolUse",
      "matcher": "",
      "hook": {
        "type": "command",
        "command": "${CLAUDE_PROJECT_DIR}/.engine/.venv/bin/python ${CLAUDE_PROJECT_DIR}/.engine/tools/modes.py accept-hook"
      }
    },
    {
      "type": "hook",
      "event": "Stop",
      "matcher": "",
      "hook": {
        "type": "command",
        "command": "${CLAUDE_PROJECT_DIR}/.engine/.venv/bin/python ${CLAUDE_PROJECT_DIR}/.engine/tools/close.py"
      }
    },
    {
      "type": "mcp",
      "name": "engine-knowledge-graph",
      "definition": {
        "command": "uv",
        "args": [
          "run",
          "--directory",
          "${CLAUDE_PROJECT_DIR:-.}/.engine",
          "--frozen",
          "--",
          "python",
          "tools/knowledge_mcp_server.py"
        ]
      }
    },
    {
      "type": "gitignore",
      "key": "core-knowledge-cache",
      "lines": [
        ".engine/knowledge/.cache/"
      ]
    },
    {
      "type": "gitignore",
      "key": "core-telemetry-cache",
      "lines": [
        ".engine/telemetry/.cache/"
      ]
    }
  ],
  "depends": {}
}
